---
import ActionButton from '../../../components/app/ActionButton.astro';
import FixedFooterAction from '../../../components/app/FixedFooterAction.astro';
import PageHeader from '../../../components/app/PageHeader.astro';
import RequirementBanner from '../../../components/app/RequirementBanner.astro';
import SignaturePadMock from '../../../components/app/SignaturePadMock.astro';
import { getRoute, routes } from '../../../data/dashboard';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
	return routes.map((route) => ({ params: { routeId: route.id } }));
}

const route = getRoute(Astro.params.routeId);
---

<Layout title={`Signature - ${route.id}`}>
	<main
		class="mx-auto flex h-dvh w-full max-w-md flex-col overflow-hidden bg-app text-text-primary shadow-2xl shadow-neutral-300/60"
		data-proof-return-root
		data-counterparty-href={`/routes/${route.id}/counterparty-proof/`}>
		<PageHeader title="Customer Signature" backHref={`/routes/${route.id}/counterparty-proof/`} backLabel="Close signature" />
		<div class="no-scrollbar flex-1 space-y-4 overflow-y-auto p-4 pb-32">
			<RequirementBanner tone="info" icon="pen">
				Ask the customer or supplier representative to sign inside the pad.
			</RequirementBanner>
			<SignaturePadMock />
			<div class="grid grid-cols-2 gap-2">
				<ActionButton variant="secondary" full>Clear</ActionButton>
				<ActionButton href={`/routes/${route.id}/counterparty-proof/`} full icon="check-circle">Use Signature</ActionButton>
			</div>
			<SignaturePadMock empty />
			<RequirementBanner tone="warning" icon="warning">
				Empty state: Use Signature remains disabled until strokes exist.
			</RequirementBanner>
		</div>
		<FixedFooterAction>
			<ActionButton href={`/routes/${route.id}/counterparty-proof/`} variant="secondary" full>Close Without Saving</ActionButton>
		</FixedFooterAction>

		<script is:inline>
			const proofReturnRoot = document.querySelector("[data-proof-return-root]");
			const returnTo = new URLSearchParams(window.location.search).get("returnTo");
			const isSafeReturn = returnTo?.startsWith("/") && !returnTo.startsWith("//");

			if (proofReturnRoot && isSafeReturn) {
				const counterpartyHref = proofReturnRoot.dataset.counterpartyHref;

				proofReturnRoot.querySelectorAll("a").forEach((link) => {
					if (link.getAttribute("href") === counterpartyHref) {
						link.setAttribute("href", returnTo);
					}
				});
			}
		</script>
	</main>
</Layout>
