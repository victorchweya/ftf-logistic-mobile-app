---
import ActionButton from '../../../components/app/ActionButton.astro';
import CameraPreviewMock from '../../../components/app/CameraPreviewMock.astro';
import DataCard from '../../../components/app/DataCard.astro';
import FixedFooterAction from '../../../components/app/FixedFooterAction.astro';
import PageHeader from '../../../components/app/PageHeader.astro';
import RequirementBanner from '../../../components/app/RequirementBanner.astro';
import { getRoute, routes } from '../../../data/dashboard';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
	return routes.map((route) => ({ params: { routeId: route.id } }));
}

const route = getRoute(Astro.params.routeId);
---

<Layout title={`Proof Camera - ${route.id}`}>
	<main class="mx-auto flex h-dvh w-full max-w-md flex-col overflow-hidden bg-app text-text-primary shadow-2xl shadow-neutral-300/60">
		<PageHeader title="Proof Camera" backHref={`/routes/${route.id}/`} backLabel="Close camera" />
		<div class="no-scrollbar flex-1 space-y-4 overflow-y-auto p-4 pb-32">
			<CameraPreviewMock mode="live" />
			<RequirementBanner tone="brand" icon="camera">
				Captured produce and invoice photos save back to the active stop proof draft.
			</RequirementBanner>
			<DataCard class="space-y-3">
				<div class="flex items-center justify-between gap-3">
					<span class="text-sm font-semibold text-text-strong">Camera permission</span>
					<span class="text-xs font-semibold text-brand">Granted</span>
				</div>
				<div class="grid grid-cols-3 gap-2">
					<ActionButton variant="secondary" icon="sun" full>Torch</ActionButton>
					<ActionButton variant="secondary" icon="refresh" full>Flip</ActionButton>
					<ActionButton variant="secondary" icon="scan" full>Scan</ActionButton>
				</div>
			</DataCard>
			<DataCard class="space-y-3">
				<h2 class="font-semibold text-text-strong">Invoice document scan</h2>
				<CameraPreviewMock mode="scan" />
			</DataCard>
		</div>
		<FixedFooterAction>
			<div class="grid grid-cols-2 gap-2">
				<ActionButton href={`/routes/${route.id}/`} variant="secondary" full>Retake</ActionButton>
				<ActionButton href={`/routes/${route.id}/`} full icon="check-circle">Use Photo</ActionButton>
			</div>
		</FixedFooterAction>
	</main>
</Layout>
