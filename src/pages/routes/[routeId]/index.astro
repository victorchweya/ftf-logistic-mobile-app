---
import ActionButton from "../../../components/app/ActionButton.astro";
import AppShell from "../../../components/app/AppShell.astro";
import DataCard from "../../../components/app/DataCard.astro";
import EmptyState from "../../../components/app/EmptyState.astro";
import FixedFooterAction from "../../../components/app/FixedFooterAction.astro";
import Icon from "../../../components/app/Icon.astro";
import PageHeader from "../../../components/app/PageHeader.astro";
import StatusChip from "../../../components/app/StatusChip.astro";
import StopDetailContent from "../../../components/app/StopDetailContent.astro";
import type { StopItem } from "../../../data/dashboard";
import {
	accountProfile,
	formatStopOrderWindow,
	getRoute,
	navItems,
	routes,
} from "../../../data/dashboard";
import Layout from "../../../layouts/Layout.astro";

export function getStaticPaths() {
	return routes.map((route) => ({ params: { routeId: route.id } }));
}

type PreviewStopState = "completed" | "current" | "upcoming";

interface PreviewStop {
	sequence: number;
	state: PreviewStopState;
	title: string;
	subtitle: string;
	sourceStop: StopItem;
}

const route = getRoute(Astro.params.routeId);
const routeNavItems = navItems.map((item) => ({
	...item,
	isActive: item.label === "Routes",
}));
const finalizedStopCount = route.stops.length
	? route.stops.filter(
			(stop) => stop.status === "completed" || stop.status === "rejected",
		).length
	: route.completedStops;
const previewStepNumber = finalizedStopCount;
const previewProgressPercent =
	(previewStepNumber / Math.max(1, route.stopCount)) * 100;

const routeTypeMeta = {
	delivery: {
		icon: "truck",
		label: "Delivery",
		className: "text-brand",
	},
	collection: {
		icon: "warehouse",
		label: "Collection",
		className: "text-status-collection",
	},
	mixed: {
		icon: "route",
		label: "Mixed",
		className: "text-status-info",
	},
} as const;

const routeType = routeTypeMeta[route.kind];
const packageCount = route.stops.length || route.stopCount;
const activeStop = route.stops.find(
	(stop) => Boolean(stop.isCurrent) || stop.status === "arrived",
);
const currentLegLabel = activeStop?.siteName ?? route.currentLeg;

const previewStops: PreviewStop[] = route.stops
	.map((stop) => {
		const isCompleted =
			stop.status === "completed" || stop.status === "rejected";
		const isCurrent = Boolean(stop.isCurrent) || stop.status === "arrived";
		const subtitle = /^\d+\s+min$/i.test(stop.eta)
			? `ETA: ${stop.eta}`
			: stop.eta;

		return {
			sequence: stop.sequence,
			state: isCompleted
				? "completed"
				: isCurrent
					? "current"
					: "upcoming",
			title: stop.siteName,
			subtitle,
			sourceStop: stop,
		};
	})
	.sort((left, right) => {
		const priority = {
			completed: 0,
			current: 1,
			upcoming: 2,
		};

		return priority[left.state] - priority[right.state];
	});

const cta =
	route.status === "assigned" && route.loadCheckRequired
		? {
				label: "Complete Load Check",
				href: `/routes/${route.id}/load-check/`,
				icon: "list",
				disabled: false,
			}
		: route.status === "assigned"
			? {
					label: "Start Route",
					href: `/routes/${route.id}/`,
					icon: "navigation",
					disabled: false,
				}
			: route.status === "active"
				? {
						label: "Navigate To Next Stop",
						href: undefined,
						icon: "navigation",
						disabled: true,
					}
				: route.status === "ready_to_complete"
					? {
							label: "Complete Route",
							href: "/dashboard/",
							icon: "check-circle",
							disabled: false,
						}
					: undefined;
---

<Layout title={`${route.id} - Hybrid Logistics`}>
	<AppShell
		driverName={accountProfile.name}
		driverInitials={accountProfile.initials}
		navItems={routeNavItems}
		contentClass="p-0"
		showNav={false}>
		<PageHeader
			slot="header"
			title={`${route.id} - ${routeType.label} Route`}
			titleClass={routeType.className}
			titleIcon={routeType.icon}
			status={route.status}
			backHref="/dashboard/"
		/>

		<div class="min-h-full bg-app" data-route-detail>
			<section
				class="relative h-[132px] bg-surface-muted"
				aria-label="Route map preview">
				<div
					class="absolute bottom-4 left-4 inline-flex h-8 items-center gap-2 rounded-md bg-surface px-3 text-[10px] font-semibold text-text-primary shadow-card">
					<span class="h-2 w-2 rounded-full bg-notification"></span>
					<span>LIVE GPS ACTIVE</span>
				</div>
				<button
					type="button"
					class="absolute bottom-4 right-4 flex h-9 w-9 items-center justify-center rounded-full bg-surface text-brand shadow-card focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
					aria-label="Center route map">
					<Icon name="home" class="text-lg" strokeWidth={2.5} />
				</button>
			</section>

			<section class="space-y-6 px-4 pb-32 pt-4">
				<div class="space-y-3">
					<div class="flex items-center justify-between gap-3">
						<h2
							class="text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">
							Progress Tracker
						</h2>
						<p class="text-sm font-semibold text-brand">
							{previewStepNumber} of {route.stopCount} Stops
						</p>
					</div>
					<div
						class="h-1.5 overflow-hidden rounded-full bg-neutral-200">
						<div
							class="h-full rounded-full bg-brand"
							style={`width: ${previewProgressPercent}%`}>
						</div>
					</div>
				</div>

				<DataCard as="section" class="space-y-4">
					<div class="space-y-3">
						<div class="flex items-center justify-between gap-3">
							<div>
								<p
									class="text-[11px] font-semibold uppercase tracking-[0.08em] text-text-secondary">
									Trip Details
								</p>
								<p
									class="mt-1 text-sm font-semibold text-text-strong">
									1 Delivery, 2 pickups
								</p>
							</div>
							<div class="text-right">
								<p class="text-md font-semibold text-brand">
									{route.weightKg} KG
								</p>
								<p
									class="mt-0.5 text-xs font-medium text-text-secondary">
									{packageCount} packages
								</p>
							</div>
						</div>

						<div class="border-t border-border pt-3">
							<div
								class="flex items-center justify-between gap-3">
								<div class="min-w-0">
									<p
										class="text-[11px] font-semibold uppercase tracking-[0.08em] text-text-secondary">
										Current Leg
									</p>
									<p
										class="mt-1 text-sm font-semibold text-text-strong">
										{currentLegLabel}
									</p>
								</div>
								<div class="relative shrink-0">
									<button
										type="button"
										class="inline-flex h-8 items-center justify-center gap-1.5 rounded-md border border-border bg-surface px-2 text-xs font-semibold text-text-primary shadow-card transition-colors duration-200 hover:bg-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
										data-route-actions-trigger
										aria-haspopup="menu"
										aria-expanded="false"
										aria-controls="route-actions-menu">
										<Icon
											name="dots"
											class="text-base text-text-muted"
										/>
									</button>
									<div
										id="route-actions-menu"
										class="absolute right-0 top-[calc(100%+0.375rem)] z-30 w-40 overflow-hidden rounded-lg border border-border bg-surface py-1 shadow-card-hover"
										data-route-actions-menu
										role="menu"
										aria-label="Route actions"
										hidden>
										<button
											type="button"
											class="flex w-full items-center gap-2 px-3 py-2 text-left text-xs font-medium text-text-primary hover:bg-neutral-200 focus-visible:bg-neutral-200 focus-visible:outline-none"
											data-route-action-item
											role="menuitem">
											<Icon
												name="route"
												class="text-sm text-brand"
											/>
											Open route
										</button>
										<button
											type="button"
											class="flex w-full items-center gap-2 px-3 py-2 text-left text-xs font-medium text-text-primary hover:bg-neutral-200 focus-visible:bg-neutral-200 focus-visible:outline-none"
											data-route-action-item
											role="menuitem">
											<Icon
												name="share"
												class="text-sm text-text-secondary"
											/>
											Share route
										</button>
										<button
											type="button"
											class="flex w-full items-center gap-2 px-3 py-2 text-left text-xs font-medium text-text-primary hover:bg-neutral-200 focus-visible:bg-neutral-200 focus-visible:outline-none"
											data-route-action-item
											role="menuitem">
											<Icon
												name="copy"
												class="text-sm text-text-secondary"
											/>
											Copy route
										</button>
									</div>
								</div>
							</div>
						</div>
					</div>

					<div class="space-y-3 border-t border-border pt-3">
						<div>
							<p
								class="text-[11px] font-semibold uppercase tracking-[0.08em] text-text-secondary">
								Proof Sync
							</p>
							<p
								class="mt-1 text-sm font-semibold text-text-strong">
								{route.syncHint}
							</p>
						</div>
						<div>
							<p
								class="text-[11px] font-semibold uppercase tracking-[0.08em] text-text-secondary">
								Dispatch Updates
							</p>
							<p class="mt-1 text-sm text-text-primary">
								{
									route.dispatchUpdate ??
										"No dispatch updates for this route."
								}
							</p>
						</div>
					</div>
				</DataCard>

				<div class="space-y-3">
					<div class="flex items-center justify-between gap-3">
						<h2
							class="text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">
							Stop Schedule
						</h2>
					</div>

					<div class="relative pl-12">
						<div
							class="absolute bottom-7 left-[15px] top-5 w-px bg-border">
						</div>
						<div class="space-y-3">
							{
								previewStops.length ? (
									previewStops.map((stop) => {
										const stopTaskType =
											routeTypeMeta[
												stop.sourceStop.taskType
											];
										const previewStatus =
											stop.sourceStop.status ===
											"rejected"
												? "rejected"
												: stop.sourceStop.status ===
													  "completed"
													? "completed"
													: stop.state === "current"
														? "active"
														: "pending";
										const isFinalStop =
											stop.state === "completed";

										return (
											<article
												class:list={[
													"relative rounded-xl border px-3 py-3",
													stop.state === "completed"
														? "bg-neutral-200"
														: "bg-surface",
													stop.state === "current"
														? "border-neutral-300 shadow-card-hover"
														: "border-border shadow-card",
												]}>
												<div
													class:list={[
														"absolute -left-[46px] top-3 z-10 flex h-8 w-8 items-center justify-center rounded-full text-xs font-semibold",
														stop.state ===
														"completed"
															? "border border-green-200 bg-green-100 text-brand"
															: stop.state ===
																  "current"
																? "bg-brand text-neutral-50 shadow-card"
																: "border border-border bg-surface text-text-muted",
													]}>
													{stop.state ===
													"completed" ? (
														<Icon
															name="check"
															class="text-base"
															strokeWidth={2.5}
														/>
													) : (
														stop.sequence
													)}
												</div>
												<button
													type="button"
													class="block w-full text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
													data-stop-drawer-trigger
													data-stop-drawer-target={`preview-stop-${stop.sourceStop.id}`}
													aria-haspopup="dialog"
													aria-controls="preview-stop-drawer"
													aria-label={`View details for ${stop.sourceStop.siteName}`}>
													<div class="flex items-start justify-between gap-3">
														<div class="min-w-0">
															<div
																class:list={[
																	"flex min-w-0 items-center gap-1.5 text-sm font-semibold",
																	stopTaskType.className,
																]}>
																<Icon
																	name={
																		stopTaskType.icon
																	}
																	class="text-sm"
																/>
																<h3 class="truncate text-xs font-medium">
																	{
																		stopTaskType.label
																	}
																</h3>
															</div>
															<p
																class:list={[
																	"mt-2 truncate text-base font-semibold",
																	isFinalStop &&
																		"text-neutral-500 line-through",
																]}>
																{stop.title}
															</p>
															<p class="mt-1 truncate text-xs font-medium text-neutral-500">
																{
																	formatStopOrderWindow(
																		stop.sourceStop,
																	)
																}
															</p>
															<p class="mt-1 truncate text-xs text-text-secondary">
																{stop.subtitle}
															</p>
														</div>
														<StatusChip
															status={
																previewStatus
															}
														/>
													</div>
												</button>
												{stop.state === "current" && (
													<a
														href={`/routes/${route.id}/stops/${stop.sourceStop.id}/arrival/`}
														class="mt-3 inline-flex h-9 w-full items-center justify-center gap-2 rounded-md bg-brand px-4 text-sm font-semibold text-neutral-50 transition-colors duration-200 hover:bg-brand/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">
														<Icon
															name="navigation"
															class="text-base"
															strokeWidth={2.5}
														/>
														I've Arrived
													</a>
												)}
											</article>
										);
									})
								) : (
									<EmptyState
										icon="check-circle"
										title="All stops finalized"
										message="This route has no remaining stop work in the prototype data."
									/>
								)
							}
						</div>
					</div>
				</div>
			</section>

			{
				cta && (
					<FixedFooterAction>
						<ActionButton
							href={cta.href}
							full
							icon={cta.icon}
							disabled={cta.disabled}>
							{cta.label}
						</ActionButton>
					</FixedFooterAction>
				)
			}

			<div
				id="preview-stop-drawer"
				class="fixed inset-0 z-[70] flex items-end justify-center"
				data-stop-drawer-root
				aria-hidden="true"
				hidden>
				<button
					type="button"
					class="absolute inset-0 bg-neutral-900/40"
					data-stop-drawer-close
					aria-label="Close stop details">
				</button>
				<div
					class="relative z-10 max-h-[85dvh] w-full max-w-md overflow-y-auto rounded-t-xl border border-border bg-surface p-4 pb-[calc(1rem+env(safe-area-inset-bottom))] shadow-[0_-8px_24px_rgb(8_8_8_/_0.12)]"
					role="dialog"
					aria-modal="true"
					aria-label="Stop details"
					tabindex="-1"
					data-stop-drawer-panel>
					<div
						class="mx-auto mb-3 h-1 w-10 rounded-full bg-neutral-300">
					</div>
					{
						previewStops.map((stop) => (
							<section
								id={`preview-stop-${stop.sourceStop.id}`}
								data-stop-drawer-content
								hidden>
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<div class="flex items-center gap-2">
											<h2 class="truncate text-base font-semibold text-text-strong">
												{stop.sourceStop.siteName}
											</h2>
											<StatusChip
												status={stop.sourceStop.status}
											/>
										</div>
										<p class="mt-1 truncate text-xs text-text-secondary">
											{
												formatStopOrderWindow(
													stop.sourceStop,
												)
											}
										</p>
										<p class="mt-1 text-sm text-text-primary">
											{stop.sourceStop.address}
										</p>
									</div>
									<button
										type="button"
										class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-text-muted transition-colors duration-200 hover:bg-neutral-200 hover:text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
										data-stop-drawer-close
										aria-label="Close stop details">
										<Icon name="close" class="text-lg" />
									</button>
								</div>
								<StopDetailContent
									stop={stop.sourceStop}
									routeId={route.id}
									class="mt-4"
								/>
							</section>
						))
					}
				</div>
			</div>
		</div>

		<script is:inline>
			const routeDetail = document.querySelector("[data-route-detail]");

			if (routeDetail) {
				const drawerRoot = routeDetail.querySelector(
					"[data-stop-drawer-root]",
				);
				const drawerPanel = drawerRoot?.querySelector(
					"[data-stop-drawer-panel]",
				);
				const drawerContents = drawerRoot
					? Array.from(
							drawerRoot.querySelectorAll(
								"[data-stop-drawer-content]",
							),
						)
					: [];
				const routeActionsTrigger = routeDetail.querySelector(
					"[data-route-actions-trigger]",
				);
				const routeActionsMenu = routeDetail.querySelector(
					"[data-route-actions-menu]",
				);
				const routeActionItems = routeActionsMenu
					? Array.from(
							routeActionsMenu.querySelectorAll(
								"[data-route-action-item]",
							),
						)
					: [];
				let lastDrawerTrigger = null;
				const closestElement = (target, selector) =>
					target instanceof Element ? target.closest(selector) : null;
				const setRouteActionsOpen = (isOpen, restoreFocus = false) => {
					if (!routeActionsTrigger || !routeActionsMenu) {
						return;
					}

					routeActionsMenu.hidden = !isOpen;
					routeActionsTrigger.setAttribute(
						"aria-expanded",
						String(isOpen),
					);

					if (isOpen) {
						requestAnimationFrame(() => {
							routeActionItems[0]?.focus();
						});
					} else if (restoreFocus) {
						routeActionsTrigger.focus();
					}
				};
				const openStopDrawer = (targetId, trigger) => {
					if (!drawerRoot || !drawerPanel || !targetId) {
						return;
					}

					const selectedContent = drawerContents.find(
						(content) => content.id === targetId,
					);

					if (!selectedContent) {
						return;
					}

					drawerContents.forEach((content) => {
						content.hidden = content !== selectedContent;
					});
					lastDrawerTrigger = trigger;
					drawerRoot.hidden = false;
					drawerRoot.setAttribute("aria-hidden", "false");
					document.body.style.overflow = "hidden";

					requestAnimationFrame(() => {
						const closeButton = selectedContent.querySelector(
							"[data-stop-drawer-close]",
						);
						(closeButton || drawerPanel).focus();
					});
				};
				const closeStopDrawer = () => {
					if (!drawerRoot || drawerRoot.hidden) {
						return;
					}

					drawerRoot.hidden = true;
					drawerRoot.setAttribute("aria-hidden", "true");
					document.body.style.overflow = "";
					drawerContents.forEach((content) => {
						content.hidden = true;
					});

					if (lastDrawerTrigger instanceof HTMLElement) {
						lastDrawerTrigger.focus();
					}

					lastDrawerTrigger = null;
				};

				routeDetail.addEventListener("click", (event) => {
					const routeActionsControl = closestElement(
						event.target,
						"[data-route-actions-trigger]",
					);

					if (routeActionsControl) {
						event.preventDefault();
						setRouteActionsOpen(
							routeActionsMenu?.hidden ?? true,
							false,
						);
						return;
					}

					const routeActionItem = closestElement(
						event.target,
						"[data-route-action-item]",
					);

					if (routeActionItem) {
						event.preventDefault();
						setRouteActionsOpen(false, true);
						return;
					}

					if (
						routeActionsMenu &&
						!routeActionsMenu.hidden &&
						!closestElement(
							event.target,
							"[data-route-actions-menu]",
						)
					) {
						setRouteActionsOpen(false);
					}

					const closeControl = closestElement(
						event.target,
						"[data-stop-drawer-close]",
					);

					if (closeControl) {
						closeStopDrawer();
						return;
					}

					const trigger = closestElement(
						event.target,
						"[data-stop-drawer-trigger]",
					);

					if (!trigger || !routeDetail.contains(trigger)) {
						return;
					}

					openStopDrawer(trigger.dataset.stopDrawerTarget, trigger);
				});

				routeDetail.addEventListener("keydown", (event) => {
					const isRouteActionItem = closestElement(
						event.target,
						"[data-route-action-item]",
					);

					if (
						isRouteActionItem &&
						(event.key === "Enter" || event.key === " ")
					) {
						event.preventDefault();
						setRouteActionsOpen(false, true);
						return;
					}

					const trigger = closestElement(
						event.target,
						"[data-stop-drawer-trigger]",
					);

					if (
						!trigger ||
						event.target !== trigger ||
						(event.key !== "Enter" && event.key !== " ")
					) {
						return;
					}

					event.preventDefault();
					openStopDrawer(trigger.dataset.stopDrawerTarget, trigger);
				});

				document.addEventListener("keydown", (event) => {
					if (
						event.key === "Escape" &&
						routeActionsMenu &&
						!routeActionsMenu.hidden
					) {
						setRouteActionsOpen(false, true);
						return;
					}

					if (
						event.key === "Escape" &&
						drawerRoot &&
						!drawerRoot.hidden
					) {
						closeStopDrawer();
					}
				});
			}
		</script>
	</AppShell>
</Layout>
