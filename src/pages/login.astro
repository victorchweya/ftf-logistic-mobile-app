---
import ActionButton from '../components/app/ActionButton.astro';
import DataCard from '../components/app/DataCard.astro';
import Icon from '../components/app/Icon.astro';
import RequirementBanner from '../components/app/RequirementBanner.astro';
import { demoAccounts } from '../data/dashboard';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login - Hybrid Logistics">
	<main class="mx-auto flex min-h-dvh w-full max-w-md flex-col bg-app px-4 py-8 text-text-primary">
		<section class="mb-6 text-center">
			<div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-brand text-neutral-50 shadow-card">
				<Icon name="package" class="text-3xl" strokeWidth={2.5} />
			</div>
			<h1 class="mt-4 text-2xl font-bold tracking-tight text-text-strong">Logistics App</h1>
			<p class="mt-1 text-sm text-text-secondary">Secure field access for today's assigned routes.</p>
		</section>

		<DataCard class="space-y-5">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">Remembered Account</p>
				<div class="mt-3 flex items-center justify-between gap-3 rounded-lg bg-surface-muted p-3">
					<div class="min-w-0">
						<p class="truncate text-sm font-semibold text-text-strong">Harvey Henson</p>
						<p class="truncate text-xs text-text-secondary">OTP will be sent to +254 *** 880</p>
					</div>
					<Icon name="shield" class="text-xl text-brand" />
				</div>
			</div>

			<label class="block">
				<span class="text-sm font-semibold text-text-strong">Fleet email</span>
				<input
					class="mt-2 h-12 w-full rounded-md border border-border bg-surface px-3 text-sm text-text-strong outline-none focus:border-brand focus:ring-2 focus:ring-brand/20"
					value="harvey.henson@hybrid.example"
				/>
			</label>

			<div>
				<p class="mb-2 text-sm font-semibold text-text-strong">Enter 4-digit OTP</p>
				<div class="grid grid-cols-4 gap-2">
					{['4', '8', '', ''].map((digit) => <input class="h-14 rounded-lg border border-border bg-surface-muted text-center text-xl font-bold text-text-strong outline-none focus:border-brand focus:ring-2 focus:ring-brand/20" value={digit} inputmode="numeric" maxlength="1" />)}
				</div>
				<p class="mt-2 text-xs text-text-secondary">Resend available in 00:28</p>
			</div>

			<RequirementBanner tone="info" icon="fingerprint">Returning users can unlock with PIN or fingerprint after OTP verification.</RequirementBanner>

			<ActionButton href="/" full icon="key">Verify OTP</ActionButton>
			<div class="grid grid-cols-2 gap-2">
				<ActionButton href="/" variant="secondary" full icon="lock">Use PIN</ActionButton>
				<ActionButton href="/" variant="secondary" full icon="fingerprint">Fingerprint</ActionButton>
			</div>
		</DataCard>

		<section class="mt-5 space-y-3">
			<p class="text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">Demo accounts</p>
			<div class="grid grid-cols-3 gap-2">
				{
					demoAccounts.map((account) => (
						<a href="/" class="rounded-lg border border-border bg-surface p-3 text-center shadow-card">
							<p class="text-xs font-bold text-text-strong">{account.label}</p>
							<p class="mt-1 truncate text-[10px] text-text-secondary">{account.role}</p>
						</a>
					))
				}
			</div>
		</section>

		<p class="mt-auto pt-8 text-center text-xs text-text-muted">Hybrid Logistics v0.4.2</p>
	</main>
</Layout>
