---
import ActionButton from '../components/app/ActionButton.astro';
import AppShell from '../components/app/AppShell.astro';
import EmptyState from '../components/app/EmptyState.astro';
import NotificationCard from '../components/app/NotificationCard.astro';
import PageHeader from '../components/app/PageHeader.astro';
import RequirementBanner from '../components/app/RequirementBanner.astro';
import { accountProfile, navItems } from '../data/dashboard';
import { notifications } from '../data/notifications';
import Layout from '../layouts/Layout.astro';

const notificationsNavItems = navItems.map((item) => ({ ...item, isActive: false }));
const unreadCount = notifications.filter((notification) => notification.unread).length;
---

<Layout title="Notifications - Hybrid Logistics">
	<AppShell
		driverName={accountProfile.name}
		driverInitials={accountProfile.initials}
		navItems={notificationsNavItems}
		contentClass="space-y-4 p-4">
		<PageHeader slot="header" title="Notifications" backHref="/dashboard/" />

		<RequirementBanner tone={unreadCount ? 'brand' : 'success'} icon="bell">
			{unreadCount ? `${unreadCount} unread route updates need a quick look.` : 'All caught up'}
		</RequirementBanner>

		<div class="flex items-center justify-between gap-2">
			<ActionButton variant="secondary" icon="refresh">Refresh</ActionButton>
			<div class="flex gap-2">
				<ActionButton variant="ghost">Mark read</ActionButton>
				<ActionButton variant="ghost">Clear</ActionButton>
			</div>
		</div>

		<section class="space-y-3" aria-labelledby="recent-activity-title">
			<h2
				id="recent-activity-title"
				class="px-1 text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">
				Recent Activity
			</h2>
			{
				notifications.length ? (
					<div class="space-y-2">
						{notifications.map((notification) => <NotificationCard notification={notification} />)}
					</div>
				) : (
					<EmptyState
						icon="bell"
						title="No notifications"
						message="Route updates, dispatch notes, and proof sync alerts will appear here."
					/>
				)
			}
		</section>
	</AppShell>
</Layout>
