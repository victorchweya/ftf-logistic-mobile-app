---
import '@phosphor-icons/web/regular';
import '@phosphor-icons/web/bold';
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Hybrid Logistics' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta
			name="description"
			content="Hybrid Logistics driver dashboard for route, stop, and delivery workflows."
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-dvh bg-app text-text-primary antialiased selection:bg-brand selection:text-neutral-50">
		<slot />
	</body>
</html>
