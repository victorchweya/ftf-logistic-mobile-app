---
import Icon from './Icon.astro';

interface Props {
	mode?: 'live' | 'captured' | 'scan';
}

const { mode = 'live' } = Astro.props;
---

<div class="relative aspect-[3/4] overflow-hidden rounded-2xl border border-neutral-700 bg-neutral-900 text-neutral-50 shadow-card">
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(223,237,223,0.24),transparent_30%),linear-gradient(135deg,rgba(255,255,255,0.08),transparent_45%)]"></div>
	<div class="absolute inset-6 rounded-xl border border-neutral-50/40"></div>
	<div class="absolute left-4 right-4 top-4 flex items-center justify-between text-xs font-semibold">
		<span>{mode === 'scan' ? 'Invoice scan' : mode === 'captured' ? 'Preview' : 'Live camera'}</span>
		<span class="rounded-full bg-neutral-50/15 px-2 py-1">3 / 15</span>
	</div>
	<div class="absolute inset-0 flex items-center justify-center">
		<div class="flex h-16 w-16 items-center justify-center rounded-full border border-neutral-50/30 bg-neutral-50/10">
			<Icon name={mode === 'scan' ? 'scan' : 'camera'} class="text-3xl" />
		</div>
	</div>
	<div class="absolute bottom-5 left-1/2 h-14 w-14 -translate-x-1/2 rounded-full border-4 border-neutral-50 bg-neutral-50/20"></div>
</div>
