---
import Icon from './Icon.astro';

interface Fact {
	icon: any;
	label: string;
	value: string;
}

interface Props {
	facts: Fact[];
	columns?: 2 | 3;
}

const { facts, columns = 3 } = Astro.props;
---

<div class={`grid gap-2 ${columns === 2 ? 'grid-cols-2' : 'grid-cols-3'}`}>
	{
		facts.map((fact) => (
			<div class="min-w-0 rounded-lg bg-surface-muted p-2.5">
				<div class="flex items-center gap-1.5 text-text-secondary">
					<Icon name={fact.icon} class="text-sm" />
					<span class="truncate text-[11px] font-medium">{fact.label}</span>
				</div>
				<p class="mt-1 truncate text-xs font-semibold text-text-strong">{fact.value}</p>
			</div>
		))
	}
</div>
