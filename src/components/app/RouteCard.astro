---
import type { RouteSummary } from "../../data/dashboard";
import FactGrid from "./FactGrid.astro";
import Icon from "./Icon.astro";
import RequirementBanner from "./RequirementBanner.astro";
import StatusChip from "./StatusChip.astro";

interface Props {
	route: RouteSummary;
}

const { route } = Astro.props;

const routeTypeMeta = {
	delivery: {
		icon: "truck",
		label: "Delivery Route",
		className: "text-brand",
	},
	collection: {
		icon: "warehouse",
		label: "Collection Route",
		className: "text-status-collection",
	},
	mixed: {
		icon: "route",
		label: "Mixed Route",
		className: "text-status-info",
	},
} as const;

const routeType = routeTypeMeta[route.kind];

const facts = [
	{
		icon: "truck",
		label: "Vehicle",
		value: route.vehicleType,
	},
	{
		icon: "package",
		label: "Stops",
		value: `${route.completedStops}/${route.stopCount}`,
	},
	{
		icon: "scale",
		label: "Weight",
		value: `${route.weightKg} kg`,
	},
] as const;
---

<a
	href={`/routes/${route.id}/`}
	aria-label={`View details for route ${route.id}`}
	class="block rounded-xl border border-border bg-surface p-3 shadow-card transition duration-200 hover:border-neutral-300 hover:shadow-card-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 active:bg-neutral-50">
	<article>
		<div class="mb-3 flex items-start justify-between gap-3">
			<div class="flex min-w-0 items-center gap-1.5">
				<div
					class={`flex min-w-0 items-center gap-1.5 text-sm font-semibold ${routeType.className}`}>
					<Icon name={routeType.icon} class="text-base" />
					<h3 class="truncate text-base font-semibold">{route.id}</h3>
					<span class="text-text-muted">-</span>
					<span class="truncate">{routeType.label}</span>
				</div>
			</div>
			<StatusChip status={route.status} />
		</div>

		<FactGrid facts={facts} />

		{
			route.requiresProofOfDelivery && (
				<div class="mt-3">
					<RequirementBanner icon="info">
						{route.syncHint}
					</RequirementBanner>
				</div>
			)
		}
	</article>
</a>
