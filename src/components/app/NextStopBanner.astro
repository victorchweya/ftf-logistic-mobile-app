---
import type { CurrentObjective } from "../../data/dashboard";
import Icon from "./Icon.astro";
import StatusChip from "./StatusChip.astro";

interface Props {
	objective: CurrentObjective;
}

const { objective } = Astro.props;

const routeTypeMeta = {
	delivery: {
		icon: "truck",
		label: "Delivery Route",
		className: "text-brand",
	},
	collection: {
		icon: "warehouse",
		label: "Collection Route",
		className: "text-status-collection",
	},
	mixed: {
		icon: "route",
		label: "Mixed Route",
		className: "text-status-info",
	},
} as const;

const routeType = routeTypeMeta[objective.routeKind];
---

<article class="rounded-xl border border-green-100 bg-green-50 p-3 shadow-card">
	<div class="flex items-start justify-between gap-3">
		<div class="min-w-0">
			<div
				class={`flex min-w-0 items-center gap-1.5 text-sm font-semibold ${routeType.className}`}>
				<Icon name={routeType.icon} class="text-base" />
				<p class="truncate">{objective.routeId}</p>
				<span class="text-text-muted">-</span>
				<span class="truncate">{routeType.label}</span>
			</div>
			<div class="mt-2 flex min-w-0 items-start gap-2.5">
				<div
					class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-soft text-brand">
					<Icon name="location" class="text-base" />
				</div>
				<div class="min-w-0">
					<p class="truncate text-sm font-semibold text-text-strong">
						{objective.primaryAddress}
					</p>
					<p class="truncate text-xs text-text-secondary">
						{objective.secondaryAddress}
					</p>
				</div>
			</div>
		</div>
		<StatusChip status={objective.status} />
	</div>

	<a
		href={objective.href}
		class="mt-3 inline-flex h-10 w-full items-center justify-center gap-2 rounded-md bg-brand px-3 text-sm font-semibold text-neutral-50 transition-colors duration-200 hover:bg-brand/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">
		<Icon name="arrow-right" class="text-base" />
		{objective.ctaLabel}
	</a>
</article>
