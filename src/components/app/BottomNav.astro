---
import type { NavItem } from '../../data/dashboard';
import Icon from './Icon.astro';

interface Props {
	items: NavItem[];
}

const { items } = Astro.props;

const itemClass = (isActive: boolean) =>
	`flex h-full min-w-0 flex-1 flex-col items-center justify-center gap-1 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-brand ${
		isActive ? 'text-brand' : 'text-text-muted hover:bg-neutral-50 hover:text-text-secondary'
	}`;
---

<nav
	class="fixed bottom-0 left-1/2 z-50 flex h-16 w-full max-w-md -translate-x-1/2 items-center justify-around border-t border-border bg-surface/90 pb-[env(safe-area-inset-bottom)] shadow-[0_-1px_8px_rgb(8_8_8_/_0.04)] backdrop-blur-md"
	aria-label="Primary navigation"
>
	{
		items.map((item) =>
			item.href ? (
				<a href={item.href} aria-current={item.isActive ? 'page' : undefined} class={itemClass(item.isActive)}>
					<Icon name={item.icon} class="text-[22px]" strokeWidth={item.isActive ? 2.5 : 2} />
					<span class="max-w-full truncate text-[10px] font-medium">{item.label}</span>
				</a>
			) : (
				<button
					type="button"
					aria-current={item.isActive ? 'page' : undefined}
					aria-disabled={!item.isActive}
					class={itemClass(item.isActive)}
				>
					<Icon name={item.icon} class="text-[22px]" strokeWidth={item.isActive ? 2.5 : 2} />
					<span class="max-w-full truncate text-[10px] font-medium">{item.label}</span>
				</button>
			)
		)
	}
</nav>
