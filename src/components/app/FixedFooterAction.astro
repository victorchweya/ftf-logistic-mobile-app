---
interface Props {
	class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
	class={`fixed bottom-0 left-1/2 z-50 w-full max-w-md -translate-x-1/2 border-t border-border bg-surface/95 p-4 pb-[calc(1rem+env(safe-area-inset-bottom))] shadow-[0_-8px_24px_rgb(8_8_8_/_0.08)] backdrop-blur-md ${className}`}
>
	<slot />
</div>
