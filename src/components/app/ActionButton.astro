---
import Icon from './Icon.astro';

interface Props {
	href?: string;
	variant?: 'primary' | 'secondary' | 'ghost' | 'danger';
	full?: boolean;
	icon?: any;
	type?: 'button' | 'submit';
	disabled?: boolean;
	size?: 'default' | 'compact';
}

const {
	href,
	variant = 'primary',
	full = false,
	icon,
	type = 'button',
	disabled = false,
	size = 'default',
} = Astro.props;

const variants = {
	primary: 'bg-brand text-neutral-50 hover:bg-brand/90 focus-visible:ring-brand',
	secondary:
		'border border-border bg-surface text-text-primary shadow-sm hover:bg-neutral-200 focus-visible:ring-brand',
	ghost: 'bg-transparent text-text-secondary hover:bg-neutral-200 hover:text-text-primary focus-visible:ring-brand',
	danger: 'bg-red-100 text-status-error hover:bg-red-200 focus-visible:ring-status-error',
};

const sizes = {
	default: 'h-11 px-4',
	compact: 'h-8 px-2',
};

const className = `inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 ${sizes[size]} ${full ? 'w-full' : ''} ${disabled ? 'cursor-not-allowed opacity-60' : ''} ${variants[variant]}`;
---

{
	href && !disabled ? (
		<a href={href} class={className}>
			{icon && <Icon name={icon} class="text-base" />}
			<slot />
		</a>
	) : (
		<button type={type} class={className} disabled={disabled}>
			{icon && <Icon name={icon} class="text-base" />}
			<slot />
		</button>
	)
}
