---
interface Props {
	class?: string;
	as?: 'article' | 'section' | 'div';
}

const { class: className = '', as = 'article' } = Astro.props;
const classes = `rounded-xl border border-border bg-surface p-4 shadow-card ${className}`;
---

{as === 'section' ? <section class={classes}><slot /></section> : as === 'div' ? <div class={classes}><slot /></div> : <article class={classes}><slot /></article>}
