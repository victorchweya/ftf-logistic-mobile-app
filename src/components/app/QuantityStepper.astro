---
interface Props {
	label: string;
	dispatched: number;
	loaded: number;
}

const { label, dispatched, loaded } = Astro.props;
---

<div class="rounded-lg border border-border bg-surface-muted p-3">
	<div class="flex items-start justify-between gap-3">
		<div class="min-w-0">
			<p class="truncate text-sm font-semibold text-text-strong">{label}</p>
			<p class="text-xs text-text-secondary">Dispatched: {dispatched}</p>
		</div>
		<div class="flex h-10 shrink-0 items-center overflow-hidden rounded-md border border-border bg-surface">
			<button type="button" class="h-10 w-9 text-lg font-semibold text-text-secondary">-</button>
			<input
				class="h-10 w-12 border-x border-border bg-surface text-center text-sm font-semibold text-text-strong"
				value={loaded}
				inputmode="numeric"
				aria-label={`${label} loaded quantity`}
			/>
			<button type="button" class="h-10 w-9 text-lg font-semibold text-brand">+</button>
		</div>
	</div>
</div>
