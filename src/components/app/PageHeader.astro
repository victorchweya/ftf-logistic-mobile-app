---
import Icon from './Icon.astro';

interface Props {
	title: string;
	backHref?: string;
	backLabel?: string;
}

const { title, backHref = '/', backLabel = 'Back to dashboard' } = Astro.props;
---

<header class="z-20 flex h-16 w-full shrink-0 items-center border-b border-border bg-surface px-4 shadow-sm">
	<a
		href={backHref}
		class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-text-secondary transition-colors duration-200 hover:bg-neutral-200 hover:text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
		aria-label={backLabel}
	>
		<Icon name="chevron-left" class="text-xl" strokeWidth={2.5} />
	</a>
	<h1 class="flex-1 pr-9 text-center text-lg font-bold tracking-tight text-text-strong">{title}</h1>
</header>
