---
import Icon from './Icon.astro';
import StatusChip from './StatusChip.astro';

interface Props {
	title: string;
	backHref?: string;
	backLabel?: string;
	subtitle?: string;
	status?: string;
	statusLabel?: string;
	titleClass?: string;
	titleIcon?: any;
}

const {
	title,
	backHref = '/',
	backLabel = 'Back to dashboard',
	subtitle,
	status,
	statusLabel,
	titleClass = 'text-text-strong',
	titleIcon,
} = Astro.props;

const statusValue = status ?? statusLabel?.toLowerCase().replaceAll(' ', '_');
const hasRouteHeader = Boolean(subtitle || statusValue);
---

<header
	class:list={[
		'z-20 flex w-full shrink-0 items-center border-b border-border bg-surface px-4 shadow-sm',
		hasRouteHeader ? 'h-14 gap-2' : 'h-16',
	]}
>
	<a
		href={backHref}
		class:list={[
			'flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-text-secondary transition-colors duration-200 hover:bg-neutral-200 hover:text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand',
			hasRouteHeader && '-ml-2',
		]}
		aria-label={backLabel}
	>
		<Icon name="chevron-left" class="text-xl" strokeWidth={2.5} />
	</a>
	{
		hasRouteHeader ? (
			<>
				<div class="min-w-0 flex-1">
					<div class={`flex min-w-0 items-center gap-1.5 ${titleClass}`}>
						{titleIcon && <Icon name={titleIcon} class="text-base" />}
						<h1 class="truncate text-sm font-semibold tracking-tight">{title}</h1>
					</div>
					{
						subtitle && (
							<p class="mt-0.5 text-[10px] font-medium uppercase tracking-[0.08em] text-text-secondary">
								{subtitle}
							</p>
						)
					}
				</div>
				{
					statusValue && <StatusChip status={statusValue} />
				}
			</>
		) : (
			<h1 class="flex-1 pr-9 text-center text-lg font-bold tracking-tight text-text-strong">{title}</h1>
		)
	}
</header>
