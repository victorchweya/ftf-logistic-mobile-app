---
import type { CurrentObjective } from '../../data/dashboard';
import ActionButton from './ActionButton.astro';
import Icon from './Icon.astro';
import StatusChip from './StatusChip.astro';

interface Props {
	objective: CurrentObjective;
}

const { objective } = Astro.props;
---

<article class="overflow-hidden rounded-xl border border-brand/20 bg-surface shadow-card ring-1 ring-neutral-900/5">
	<div class="flex items-center justify-between gap-3 border-b border-brand/10 bg-brand/5 px-4 py-3">
		<div class="min-w-0">
			<p class="truncate font-semibold text-brand">{objective.label}</p>
		</div>
		<StatusChip status={objective.status} />
	</div>

	<div class="space-y-5 p-5">
		<div class="flex items-start gap-3.5">
			<div
				class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-soft text-brand"
			>
				<Icon name="location" class="text-[18px]" />
			</div>
			<div class="min-w-0 space-y-1">
				<p class="truncate text-base font-semibold leading-tight text-text-strong">
					{objective.primaryAddress}
				</p>
				<p class="text-sm text-text-secondary">{objective.secondaryAddress}</p>
			</div>
		</div>

		<ActionButton href={objective.href} full icon="arrow-right">{objective.ctaLabel}</ActionButton>
	</div>
</article>
