---
import type {
	NotificationItem,
	NotificationTone,
} from "../../data/notifications";
import Icon from "./Icon.astro";

interface Props {
	notification: NotificationItem;
}

const { notification } = Astro.props;

const toneClasses: Record<NotificationTone, string> = {
	brand: "bg-brand/10 text-brand",
	info: "bg-indigo-100 text-status-info",
	warning: "bg-yellow-100 text-status-warning",
	neutral: "bg-neutral-200 text-text-primary",
	success: "bg-olive-100 text-status-completed",
};
---

<article
	class={`relative rounded-xl border border-border bg-surface flex gap-4 p-4 shadow-card transition-colors duration-200 hover:bg-neutral-50 ${
		notification.unread ? "" : "opacity-90"
	}`}>
	{
		notification.unread && (
			<span
				class="absolute right-4 top-4 h-2 w-2 rounded-full bg-brand"
				aria-label="Unread notification"
			/>
		)
	}

	<div class="flex gap-4">
		<div
			class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-lg ${toneClasses[notification.tone]}`}>
			<Icon name={notification.icon} class="text-xl" />
		</div>

		<div class="min-w-0 flex-1 space-y-1">
			<div class="flex items-start justify-between gap-3 pr-3">
				<h2
					class="min-w-0 truncate text-sm font-bold leading-5 text-text-strong">
					{notification.title}
				</h2>
				<span
					class="shrink-0 text-[11px] font-medium leading-5 text-text-muted">
					{notification.timestamp}
				</span>
			</div>
			<p
				class="text-sm leading-snug text-text-secondary [&_strong]:font-semibold [&_strong]:text-text-primary"
				set:html={notification.message}
			/>
		</div>
	</div>
</article>
